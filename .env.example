PORT=3003
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3002,http://localhost:5173,http://localhost:5174

# Shared Auth RDS. The Admin service uses the same database and writes to schema admin.
DATABASE_URL=postgres://user:password@auth-rds-host:5432/autonomia_identity
DATABASE_POOL_MAX=5
DATABASE_SSL_MODE=require
DATABASE_SSL_REJECT_UNAUTHORIZED=false
AUTH_SYNC_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/140023375763/autonomia-auth-sync
FINANCIAL_SYNC_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/140023375763/autonomia-financial-sync

# Cognito/JWT validation. In local development, if JWKS_URL is empty, tokens are decoded
# and the API still returns the authenticated user shape for frontend testing.
JWT_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_UXFFwtF6E
JWT_AUDIENCE=6amud6bb0ecrmhp5sm24slk4g6
JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_UXFFwtF6E/.well-known/jwks.json

# S3 uploads for logos and profile images.
AWS_REGION=us-east-1
ADMIN_ASSETS_BUCKET=autonomia-admin-assets-140023375763-prod
# Optional. Use the Admin API /assets route locally, or a CloudFront/custom domain later.
ADMIN_ASSETS_PUBLIC_BASE_URL=https://admin.api-autonomia.com/assets
ADMIN_UPLOAD_URL_EXPIRES_SECONDS=300
